    "overview": "SkillForge original DevOps path focused on automation, delivery systems, cloud infrastructure, platform reliability, and operational feedback loops.",
    "totalWeeks": 18,
    "nodes": [
      {
        "id": "devops_foundations",
        "step": 1,
        "phase": 1,
        "title": "Linux, Networking, and Command Line Foundations",
        "description": "Start with Linux usage, shells, files, processes, permissions, networking basics, and the operational mindset required for infrastructure work.",
        "difficulty": "beginner",
        "estimatedHours": 14,
        "weekRange": "Week 1-3",
        "keyTopics": [
          "linux basics",
          "filesystem and permissions",
          "processes and services",
          "shell usage",
          "networking basics",
          "ports and protocols"
        ],
        "prerequisites": [],
        "miniProject": "Provision a Linux VM, document users, services, firewall basics, and common shell workflows.",
        "resources": [
          {
            "type": "article",
            "title": "Linux Journey",
            "platform": "linuxjourney.com",
            "url": "https://linuxjourney.com/"
          },
          {
            "type": "article",
            "title": "Networking Fundamentals",
            "platform": "Cloudflare",
            "url": "https://www.cloudflare.com/learning/network-layer/what-is-a-computer-port/"
          },
          {
            "type": "video",
            "title": "Video Guide: Linux, Networking, and Command Line Foundations",
            "platform": "YouTube Search",
            "url": "https://www.youtube.com/results?search_query=freecodecamp+linux+for+beginners"
          }
        ]
      },
