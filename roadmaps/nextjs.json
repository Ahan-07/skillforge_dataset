            "url": "https://www.youtube.com/results?search_query=vercel+deploy+nextjs+app"
          }
        ]
      },
      {
        "id": "nextjs_capstone",
        "step": 8,
        "phase": 3,
        "title": "SkillForge Next.js Studio Build",
        "description": "Combine routing, rendering, server actions, auth, persistence, testing, and deployment into a production-style application.",
        "difficulty": "advanced",
        "estimatedHours": 20,
        "weekRange": "Week 15-16",
        "keyTopics": [
          "app architecture",
          "user flows",
          "data consistency",
          "performance review",
          "security review",
          "capstone delivery"
        ],
        "prerequisites": [
