            "url": "https://www.postgresql.org/docs/current/transaction-iso.html"
          },
          {
            "type": "video",
            "title": "Video Guide: Transactions, Isolation, and Reliability",
            "platform": "YouTube Search",
            "url": "https://www.youtube.com/results?search_query=freecodecamp+database+transactions"
          }
        ]
      },
      {
        "id": "sql_capstone",
        "step": 8,
        "phase": 3,
        "title": "SkillForge SQL Studio Build",
        "description": "Design, query, optimize, and document a complete relational database for a real application.",
        "difficulty": "advanced",
        "estimatedHours": 16,
        "weekRange": "Week 10",
        "keyTopics": [
          "schema review",
          "migrations",
