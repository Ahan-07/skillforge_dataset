        "difficulty": "beginner",
        "estimatedHours": 8,
        "weekRange": "Week 1",
        "keyTopics": [
          "problem decomposition",
          "Big O",
          "time complexity",
          "space complexity",
          "trade-offs"
        ],
        "prerequisites": [],
        "miniProject": "Analyze complexity of 15 small code snippets",
        "resources": [
          {
            "type": "article",
            "title": "Big-O Cheat Sheet",
